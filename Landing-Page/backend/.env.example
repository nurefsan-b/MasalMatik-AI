# Veritabanı (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/masalmatik

# SQLite kullanmak isterseniz (geliştirme için):
# DATABASE_URL=sqlite:///./masalmatik.db

# Webhook URL (n8n veya Make)
WEBHOOK_URL=https://your-n8n-instance.com/webhook/masalmatik

# Uygulama Ayarları
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production
